#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PARENT_DIR="$(dirname "$SCRIPT_DIR")"

HOSTS_ENTRIES=(
  "127.0.0.1 private-api.auth.maintainerd.local"
  "127.0.0.1 public-api.auth.maintainerd.local"
  "127.0.0.1 console.auth.maintainerd.local"
  "127.0.0.1 identity.auth.maintainerd.local"
  "127.0.0.1 rabbitmq.auth.maintainerd.local"
  "127.0.0.1 prometheus.auth.maintainerd.local"
  "127.0.0.1 grafana.auth.maintainerd.local"
  "127.0.0.1 signoz.auth.maintainerd.local"
)

# ── usage ────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
maintainerd — local development environment manager

Usage:
  ./maintainerd init                    Clone all repositories
  ./maintainerd setup                   Configure env, hosts, and trusted local HTTPS
  ./maintainerd up  --profile=<name>    Start services (use -d for detached)
  ./maintainerd down                    Stop all services
  ./maintainerd clean                   Stop services and remove development data

Hosts (added to /etc/hosts during setup):
  private-api.auth.maintainerd.local    → Internal API (port 8080)
  public-api.auth.maintainerd.local     → Public API (port 8081)
  console.auth.maintainerd.local        → Console app
  identity.auth.maintainerd.local       → Identity app
  rabbitmq.auth.maintainerd.local       → RabbitMQ management
  prometheus.auth.maintainerd.local     → Prometheus (observed profile)
  grafana.auth.maintainerd.local        → Grafana (observed profile)
  signoz.auth.maintainerd.local         → SigNoz (observed profile)

Profiles:
  auth           Auth services only (no observability)
  auth-observed  Auth services + Prometheus + Grafana + SigNoz
  all            Everything (currently equivalent to auth-observed)

Examples:
  ./maintainerd init
  ./maintainerd setup
  ./maintainerd up --profile=auth
  ./maintainerd up --profile=auth-observed -d
  ./maintainerd down
  ./maintainerd clean
EOF
  exit 0
}

# ── helpers ───────────────────────────────────────────────────────────────────
clone_repo() {
  local repo="$1"
  local dir="${PARENT_DIR}/${repo}"
  if [ -d "$dir/.git" ]; then
    echo "  [SKIP] ${repo} already exists — pulling latest"
    (cd "$dir" && git pull --ff-only 2>/dev/null || true)
  else
    echo "  [CLONE] ${repo}"
    git clone "https://github.com/maintainerd/${repo}.git" "$dir"
  fi
}

copy_env_sample() {
  local repo="$1"
  local sample="$2"
  local target="${PARENT_DIR}/${repo}/.env"
  if [ -f "$target" ]; then
    echo "  [SKIP] ${repo}/.env already exists"
  else
    cp "${SCRIPT_DIR}/.env-samples/${sample}" "$target"
    echo "  [DONE] ${repo}/.env created from .env-samples/${sample}"
  fi
}

configure_https_env() {
  local file="$1"
  [ -f "$file" ] || return 0

  sed -i \
    -e 's|http://private-api\.auth\.maintainerd\.local|https://private-api.auth.maintainerd.local|g' \
    -e 's|http://public-api\.auth\.maintainerd\.local|https://public-api.auth.maintainerd.local|g' \
    -e 's|http://console\.auth\.maintainerd\.local|https://console.auth.maintainerd.local|g' \
    -e 's|http://identity\.auth\.maintainerd\.local|https://identity.auth.maintainerd.local|g' \
    -e 's|^COOKIE_SECURE=false$|COOKIE_SECURE=true|' \
    -e 's|^WEBAUTHN_RP_ID=localhost$|WEBAUTHN_RP_ID=auth.maintainerd.local|' \
    "$file"
}

ensure_hosts_entry() {
  local entry="$1"
  if grep -qF "$entry" /etc/hosts 2>/dev/null; then
    echo "  [SKIP] /etc/hosts already has: ${entry}"
  else
    echo "  [ADD]  /etc/hosts: ${entry}"
    echo "$entry" | sudo tee -a /etc/hosts > /dev/null
  fi
}

# ── init ──────────────────────────────────────────────────────────────────────
cmd_init() {
  echo "==> Cloning repositories into ${PARENT_DIR}"

  clone_repo "maintainerd-auth"
  clone_repo "maintainerd-auth-console"
  clone_repo "maintainerd-auth-identity"

  echo ""
  echo "==> Repos cloned. Run './maintainerd setup' to create .env files."
}

# ── setup ─────────────────────────────────────────────────────────────────────
cmd_setup() {
  echo "==> Configuring /etc/hosts"
  for entry in "${HOSTS_ENTRIES[@]}"; do
    ensure_hosts_entry "$entry"
  done

  echo ""
  echo "==> Creating .env files from samples"

  copy_env_sample "maintainerd-auth"          "maintainerd-auth.env"
  copy_env_sample "maintainerd-auth-console"  "maintainerd-auth-console.env"
  copy_env_sample "maintainerd-auth-identity" "maintainerd-auth-identity.env"

  echo ""
  echo "==> Configuring HTTPS application origins"
  configure_https_env "${PARENT_DIR}/maintainerd-auth/.env"
  configure_https_env "${PARENT_DIR}/maintainerd-auth-console/.env"
  configure_https_env "${PARENT_DIR}/maintainerd-auth-identity/.env"

  echo ""
  echo "==> Generating and trusting the local HTTPS certificate"
  "${SCRIPT_DIR}/scripts/generate-local-certs.sh" --trust

  echo ""
  echo "==> Syncing AI/agent config files to each repo"

  for repo in maintainerd-auth maintainerd-auth-console maintainerd-auth-identity; do
    target="${PARENT_DIR}/${repo}"
    if [ -d "$target" ]; then
      cp -r "${SCRIPT_DIR}/ai-files/." "$target/"
      echo "  [DONE] ${repo} — AI config synced"
    fi
  done

  echo ""
  echo "==> Done. Run './maintainerd up --profile=auth' to start the auth stack."
}

# ── up ────────────────────────────────────────────────────────────────────────
cmd_up() {
  local profile=""
  local otel_enabled="false"
  local -a compose_args=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --profile=*) profile="${1#*=}" ;;
      --profile)
        if [ "$#" -lt 2 ]; then
          echo "ERROR: --profile requires a value"
          exit 1
        fi
        profile="$2"
        shift
        ;;
      -d) compose_args+=("-d") ;;
      *) usage ;;
    esac
    shift
  done

  if [ -z "$profile" ]; then
    echo "ERROR: --profile=<name> is required"
    usage
  fi

  case "$profile" in
    auth) ;;
    auth-observed|all) otel_enabled="true" ;;
    *)
      echo "ERROR: unknown profile '${profile}'. Use 'auth', 'auth-observed', or 'all'."
      exit 1
      ;;
  esac

  echo "==> Starting profile: ${profile}"
  cd "$SCRIPT_DIR"
  "${SCRIPT_DIR}/scripts/generate-local-certs.sh"
  MAINTAINERD_OTEL_ENABLED="$otel_enabled" \
    docker compose --profile "$profile" up "${compose_args[@]}" --remove-orphans
}

# ── down ──────────────────────────────────────────────────────────────────────
cmd_down() {
  cd "$SCRIPT_DIR"
  # Activate the superset profile so Compose includes every managed service in
  # the shutdown model, regardless of which profile was used for `up`.
  docker compose --profile all down --remove-orphans
  echo "All services stopped."
}

# ── clean ────────────────────────────────────────────────────────────────────
cmd_clean() {
  cd "$SCRIPT_DIR"
  docker compose --profile all down --remove-orphans --volumes
  echo "All services stopped and development volumes removed."
}

# ── dispatch ──────────────────────────────────────────────────────────────────
case "${1:-}" in
  init)    shift; cmd_init "$@" ;;
  setup)   shift; cmd_setup "$@" ;;
  up)      shift; cmd_up "$@" ;;
  down)    shift; cmd_down "$@" ;;
  clean)   shift; cmd_clean "$@" ;;
  *)       usage ;;
esac
