# ---- Cookies ----------------------------------------------------------------
COOKIE_SECURE=true
COOKIE_SAMESITE=strict

# ---- OpenTelemetry (optional) ------------------------------------------------
OTEL_ENABLED=true
OTEL_SERVICE_NAME=maintainerd-auth
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_INSECURE=true
