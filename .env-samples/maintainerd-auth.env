# =============================================================================
# maintainerd-auth — Development Environment (Docker Compose)
# =============================================================================

APP_ENV=development
APP_VERSION=1.0.0

# ---- Hostnames --------------------------------------------------------------
APP_PUBLIC_HOSTNAME=https://public-api.auth.maintainerd.local
APP_PRIVATE_HOSTNAME=https://private-api.auth.maintainerd.local
MANAGEMENT_PORT=8082
APP_FRONTEND_IDENTITY_HOSTNAME=https://identity.auth.maintainerd.local
APP_FRONTEND_CONSOLE_HOSTNAME=https://console.auth.maintainerd.local

# ---- CORS -------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://console.auth.maintainerd.local,https://identity.auth.maintainerd.local

# ---- WebAuthn ---------------------------------------------------------------
WEBAUTHN_EXTRA_ORIGINS=https://console.auth.maintainerd.local,https://identity.auth.maintainerd.local
WEBAUTHN_RP_ID=auth.maintainerd.local

# ---- Database ---------------------------------------------------------------
DB_HOST=postgres-db
DB_PORT=5432
DB_USER=devuser
DB_PASSWORD=Pass123
DB_NAME=maintainerd
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_SEC=300
DB_STATEMENT_TIMEOUT_MS=30000

# ---- Redis ------------------------------------------------------------------
REDIS_ADDR=redis-db:6379
REDIS_PASSWORD=Pass123
REDIS_TLS=false

# ---- RabbitMQ ---------------------------------------------------------------
RABBITMQ_URL=amqp://devuser:Pass123@rabbitmq:5672/

# ---- Secret Management -------------------------------------------------------
SECRET_PROVIDER=env
SECRET_PREFIX=maintainerd/auth

